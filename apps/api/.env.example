# Neon Postgres connection string
DATABASE_URL=""
# Secret used to sign JWTs — use a long random value in production
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV="development"
# Comma-separated list of allowed web origins for CORS
CORS_ORIGIN="http://localhost:5173"

# Initial SUPERADMIN created by `npx prisma db seed` (idempotent). Optional.
SEED_SUPERADMIN_EMAIL=""
SEED_SUPERADMIN_PASSWORD=""
SEED_SUPERADMIN_NAME=""
